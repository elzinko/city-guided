# Render dashboard variables (sync: false)
# Copy to infra/config/.env.render and fill values locally (file is gitignored).

# API service (city-guided-api)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
ADMIN_TOKEN=change-me
SECRET_OPENTRIPMAP_API_KEY=

# Web service (city-guided-web)
# Host only (no trailing /api). Code also accepts .../api (AWS-style) and normalizes it.
NEXT_PUBLIC_API_URL=https://city-guided-api.onrender.com
SHOW_DEV_OPTIONS=false

# Admin service (city-guided-admin)
NEXT_PUBLIC_API_URL=https://city-guided-api.onrender.com
NEXT_PUBLIC_ADMIN_TOKEN=change-me
